# OpenAI API key (required)
OPENAI_API_KEY=your-openai-api-key
# Optional OpenAI model override
OPENAI_MODEL=gpt-4.1-mini
# Optional dedicated policy router model (defaults to OPENAI_MODEL when empty)
OPENAI_ROUTER_MODEL=
# Optional shadow router model for shadow/canary telemetry
OPENAI_ROUTER_SHADOW_MODEL=
# Enable shadow policy-router comparison telemetry
ROUTER_SHADOW_ENABLED=false
# Canary percentage [0-100] routed through OPENAI_ROUTER_SHADOW_MODEL when configured
ROUTER_CANARY_PERCENT=0
# Policy router timeout budget in seconds (must be > 0)
ROUTER_TIMEOUT_SEC=2.0
# Fail-closed threshold for router confidence in [0.0, 1.0]
POLICY_ROUTER_MIN_CONFIDENCE=0.55
# Interruption router timeout budget in seconds (must be > 0)
INTERRUPTION_ROUTER_TIMEOUT_SEC=1.5
# Minimum confidence required before auto-resuming interrupted responses
INTERRUPTION_RESUME_MIN_CONFIDENCE=0.6
# Enable LLM-assisted semantic turn-end detection before utterance commit
SEMANTIC_TURN_ENABLED=true
# Semantic turn router timeout budget in seconds (must be > 0)
SEMANTIC_TURN_ROUTER_TIMEOUT_SEC=0.8
# Minimum confidence required to keep waiting for more speech
SEMANTIC_TURN_MIN_CONFIDENCE=0.6
# Additional capture window after semantic "wait" decision (seconds)
SEMANTIC_TURN_EXTENSION_SEC=0.6
# Max transcript chars sent to semantic turn router
SEMANTIC_TURN_MAX_TRANSCRIPT_CHARS=220

# ElevenLabs API key (required for TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ElevenLabs voice ID (default: a deep, composed male voice)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Home Assistant (optional - for smart home control)
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=your-long-lived-access-token
# Home Assistant permission profile: readonly or control
HOME_PERMISSION_PROFILE=control
# Optional strict mode: require confirm=true for all non-dry-run smart_home actions
HOME_REQUIRE_CONFIRM_EXECUTE=false
# Optional: enable Home Assistant conversation intent tool
HOME_CONVERSATION_ENABLED=false
# Home Assistant conversation permission profile: readonly or control
HOME_CONVERSATION_PERMISSION_PROFILE=readonly
# Global safe mode: force dry-run/restricted behavior for mutating actions
SAFE_MODE_ENABLED=false
# Optional data retention windows (days; 0 disables pruning)
MEMORY_RETENTION_DAYS=0
AUDIT_RETENTION_DAYS=0
# Memory retrieval tuning
MEMORY_ENABLED=true
MEMORY_SEARCH_LIMIT=5
MEMORY_MAX_SENSITIVITY=0.4
MEMORY_HYBRID_WEIGHT=0.7
MEMORY_DECAY_ENABLED=false
MEMORY_DECAY_HALF_LIFE_DAYS=30
MEMORY_MMR_ENABLED=false
MEMORY_MMR_LAMBDA=0.7
# Semantic embedding retrieval (requires OPENAI_API_KEY)
MEMORY_EMBEDDING_ENABLED=false
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_BASE_URL=
MEMORY_EMBEDDING_VECTOR_WEIGHT=0.65
MEMORY_EMBEDDING_MIN_SIMILARITY=0.2
MEMORY_EMBEDDING_TIMEOUT_SEC=6.0
# LLM conflict resolution for memory add (skip duplicate / merge into existing)
MEMORY_CONFLICT_RESOLUTION_ENABLED=false
MEMORY_CONFLICT_RESOLUTION_MODEL=gpt-4.1-mini
MEMORY_CONFLICT_RESOLUTION_BASE_URL=
MEMORY_CONFLICT_RESOLUTION_TIMEOUT_SEC=4.0
# Ingestion policy gate (JSON object) and confidence threshold (0.0-1.0)
MEMORY_INGESTION_MIN_CONFIDENCE=0.0
MEMORY_INGESTION_POLICY=
# Async enrichment worker queue (embeddings/assertion indexing)
MEMORY_INGEST_ASYNC_ENABLED=false
MEMORY_INGEST_QUEUE_MAX=256
# Redact prompt-injection-like memory snippets before they are sent back to the model
MEMORY_PROMPT_SANITIZATION_ENABLED=true
# Optional PII guardrails on memory writes
MEMORY_PII_GUARDRAILS_ENABLED=true
# Optional encrypted-at-rest controls (requires JARVIS_DATA_KEY)
MEMORY_ENCRYPTION_ENABLED=false
AUDIT_ENCRYPTION_ENABLED=false
# 32+ char passphrase or Fernet key for encrypted memory/audit data
JARVIS_DATA_KEY=

# Todoist integration (optional)
TODOIST_API_TOKEN=
TODOIST_PROJECT_ID=
TODOIST_PERMISSION_PROFILE=control
# Optional request timeout (seconds, must be > 0)
TODOIST_TIMEOUT_SEC=10.0
# Optional Notion notes integration (used by integration_hub notes_capture backend=notion)
NOTION_API_TOKEN=
NOTION_DATABASE_ID=

# Pushover notifications (optional)
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=
NOTIFICATION_PERMISSION_PROFILE=allow
# interrupt | defer | adaptive
NUDGE_POLICY=adaptive
# Optional quiet-window (local time HH:MM). Leave blank to disable quiet-window deferral.
NUDGE_QUIET_HOURS_START=22:00
NUDGE_QUIET_HOURS_END=07:00
# Optional request timeout (seconds, must be > 0)
PUSHOVER_TIMEOUT_SEC=10.0

# Email send integration (optional)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_DEFAULT_TO=
EMAIL_USE_TLS=true
EMAIL_PERMISSION_PROFILE=readonly
EMAIL_TIMEOUT_SEC=10.0

# Weather integration (optional; Open-Meteo backend)
WEATHER_UNITS=metric
WEATHER_TIMEOUT_SEC=8.0

# Webhook trigger integration (optional)
# Comma-separated hostnames allowed for outbound webhook_trigger calls.
WEBHOOK_ALLOWLIST=
# Optional bearer token injected by webhook_trigger when set.
WEBHOOK_AUTH_TOKEN=
WEBHOOK_TIMEOUT_SEC=8.0
# Optional inbound webhook receiver (operator server endpoint)
WEBHOOK_INBOUND_ENABLED=false
WEBHOOK_INBOUND_TOKEN=

# Personality controls
# Persona style: terse | composed | friendly | jarvis
PERSONA_STYLE=composed
# Backchannel style: quiet | balanced | expressive
BACKCHANNEL_STYLE=balanced

# Voice attention/reliability controls
WAKE_MODE=always_listening
WAKE_CALIBRATION_PROFILE=default
WAKE_WORDS=jarvis
WAKE_WORD_SENSITIVITY=0.82
VOICE_FOLLOWUP_WINDOW_SEC=6.0
VOICE_TIMEOUT_PROFILE=normal
VOICE_TIMEOUT_SHORT_SEC=0.55
VOICE_TIMEOUT_NORMAL_SEC=0.8
VOICE_TIMEOUT_LONG_SEC=1.2
BARGE_THRESHOLD_ALWAYS_LISTENING=0.4
BARGE_THRESHOLD_WAKE_WORD=0.45
BARGE_THRESHOLD_PUSH_TO_TALK=0.5
VOICE_MIN_POST_WAKE_CHARS=4
VOICE_ROOM_DEFAULT=main

# Fallback and watchdog behavior
STT_FALLBACK_ENABLED=true
WHISPER_MODEL_FALLBACK=tiny.en
TTS_FALLBACK_TEXT_ONLY=true
MODEL_FAILOVER_ENABLED=true
# offline_stub | retry_once
MODEL_SECONDARY_MODE=offline_stub
WATCHDOG_ENABLED=true
WATCHDOG_LISTENING_TIMEOUT_SEC=30
WATCHDOG_THINKING_TIMEOUT_SEC=60
WATCHDOG_SPEAKING_TIMEOUT_SEC=45
# Max budget for action/external-call phase per turn (seconds)
TURN_TIMEOUT_ACT_SEC=30
STARTUP_STRICT=false
RUNTIME_STATE_PATH=~/.jarvis/runtime-state.json
EXPANSION_STATE_PATH=~/.jarvis/expansion-state.json
POLICY_ENGINE_PATH=config/policy-engine-v1.json
RELEASE_CHANNEL_CONFIG_PATH=config/release-channels.json
NOTES_CAPTURE_DIR=~/.jarvis/notes
QUALITY_REPORT_DIR=~/.jarvis/quality-reports
# Enable LLM-authored autonomy replan drafts (requires OpenAI API access)
AUTONOMY_LLM_REPLAN_ENABLED=false

# Operator console / observability
OPERATOR_SERVER_ENABLED=true
OPERATOR_SERVER_HOST=127.0.0.1
OPERATOR_SERVER_PORT=8765
# Operator auth mode: off | token | session
OPERATOR_AUTH_MODE=off
# Optional operator API auth token (recommended if host is non-loopback)
OPERATOR_AUTH_TOKEN=
OBSERVABILITY_ENABLED=true
OBSERVABILITY_DB_PATH=~/.jarvis/telemetry.sqlite
OBSERVABILITY_STATE_PATH=~/.jarvis/observability-state.json
OBSERVABILITY_EVENT_LOG_PATH=~/.jarvis/events.jsonl
RECOVERY_JOURNAL_PATH=~/.jarvis/recovery-journal.jsonl
DEAD_LETTER_QUEUE_PATH=~/.jarvis/dead-letter-queue.jsonl
OBSERVABILITY_FAILURE_BURST_THRESHOLD=5
OBSERVABILITY_SNAPSHOT_INTERVAL_SEC=30

# Local skills/plugin registry
SKILLS_ENABLED=true
SKILLS_DIR=~/.jarvis/skills
SKILLS_STATE_PATH=~/.jarvis/skills/.state.json
SKILLS_ALLOWLIST=
SKILLS_REQUIRE_SIGNATURE=false
SKILLS_SIGNATURE_KEY=

# Channel webhooks (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Identity and trust controls (optional)
IDENTITY_ENFORCEMENT_ENABLED=false
IDENTITY_DEFAULT_USER=owner
# deny | readonly | control | trusted
IDENTITY_DEFAULT_PROFILE=control
# Comma-separated: user=profile (example: alice=readonly,bob=trusted)
IDENTITY_USER_PROFILES=
# Comma-separated trusted requester ids
IDENTITY_TRUSTED_USERS=
# Require approval for high-risk actions (webhooks, email send, HA conversation, etc.)
IDENTITY_REQUIRE_APPROVAL=true
# Optional shared approval code for high-risk actions (use 8+ chars)
IDENTITY_APPROVAL_CODE=
# Require preview-token acknowledgment before mutating medium/high-risk actions
PLAN_PREVIEW_REQUIRE_ACK=false

# Reachy Mini connection (optional - auto-detected by default)
# REACHY_MINI_HOST=reachy-mini.local
