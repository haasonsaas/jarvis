# Claude API key (required)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ElevenLabs API key (required for TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ElevenLabs voice ID (default: a deep, composed male voice)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Home Assistant (optional - for smart home control)
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=your-long-lived-access-token
# Home Assistant permission profile: readonly or control
HOME_PERMISSION_PROFILE=control
# Optional strict mode: require confirm=true for all non-dry-run smart_home actions
HOME_REQUIRE_CONFIRM_EXECUTE=false
# Optional: enable Home Assistant conversation intent tool
HOME_CONVERSATION_ENABLED=false
# Home Assistant conversation permission profile: readonly or control
HOME_CONVERSATION_PERMISSION_PROFILE=readonly
# Optional data retention windows (days; 0 disables pruning)
MEMORY_RETENTION_DAYS=0
AUDIT_RETENTION_DAYS=0

# Todoist integration (optional)
TODOIST_API_TOKEN=
TODOIST_PROJECT_ID=
TODOIST_PERMISSION_PROFILE=control
# Optional request timeout (seconds, must be > 0)
TODOIST_TIMEOUT_SEC=10.0

# Pushover notifications (optional)
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=
NOTIFICATION_PERMISSION_PROFILE=allow
# Optional request timeout (seconds, must be > 0)
PUSHOVER_TIMEOUT_SEC=10.0

# Weather integration (optional; Open-Meteo backend)
WEATHER_UNITS=metric
WEATHER_TIMEOUT_SEC=8.0

# Webhook trigger integration (optional)
# Comma-separated hostnames allowed for outbound webhook_trigger calls.
WEBHOOK_ALLOWLIST=
# Optional bearer token injected by webhook_trigger when set.
WEBHOOK_AUTH_TOKEN=
WEBHOOK_TIMEOUT_SEC=8.0

# Channel webhooks (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Reachy Mini connection (optional - auto-detected by default)
# REACHY_MINI_HOST=reachy-mini.local
